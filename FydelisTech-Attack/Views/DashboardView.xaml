<UserControl x:Class="FydelisTech_Attack.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cards de Resumo -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,15">

            <!-- Card: Subdomínios -->
            <Border Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1"
                    CornerRadius="8" 
                    Width="200" Height="110" 
                    Margin="0,0,12,12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="SubdomainCount"
                               Text="0" 
                               FontSize="36" 
                               Foreground="{StaticResource AccentGreenBrush}" 
                               FontWeight="Bold"
                               TextAlignment="Center"/>
                    <TextBlock Text="Subdomínios" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="12"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Card: Hosts Vivos -->
            <Border Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1"
                    CornerRadius="8" 
                    Width="200" Height="110" 
                    Margin="0,0,12,12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="LiveHostCount"
                               Text="0" 
                               FontSize="36" 
                               Foreground="{StaticResource AccentCyanBrush}" 
                               FontWeight="Bold"
                               TextAlignment="Center"/>
                    <TextBlock Text="Hosts Vivos" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="12"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Card: Serviços HTTP -->
            <Border Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1"
                    CornerRadius="8" 
                    Width="200" Height="110" 
                    Margin="0,0,12,12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="HttpCount"
                               Text="0" 
                               FontSize="36" 
                               Foreground="{StaticResource AccentYellowBrush}" 
                               FontWeight="Bold"
                               TextAlignment="Center"/>
                    <TextBlock Text="Serviços HTTP" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="12"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Card: WAF -->
            <Border Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1"
                    CornerRadius="8" 
                    Width="200" Height="110" 
                    Margin="0,0,12,12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="WafStatus"
                               Text="Nenhum" 
                               FontSize="16" 
                               Foreground="{StaticResource AccentGreenBrush}" 
                               FontWeight="Bold"
                               TextAlignment="Center"/>
                    <TextBlock Text="WAF Detectado" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="12"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Card: Domínio -->
            <Border Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1"
                    CornerRadius="8" 
                    Width="200" Height="110" 
                    Margin="0,0,12,12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="DomainText"
                               Text="-" 
                               FontSize="16" 
                               Foreground="{StaticResource AccentPurpleBrush}" 
                               FontWeight="Bold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="5"/>
                    <TextBlock Text="Domínio" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="12"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Card: Duração -->
            <Border Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1"
                    CornerRadius="8" 
                    Width="200" Height="110" 
                    Margin="0,0,12,12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="DurationText"
                               Text="00:00" 
                               FontSize="36" 
                               Foreground="{StaticResource AccentOrangeBrush}" 
                               FontWeight="Bold"
                               TextAlignment="Center"/>
                    <TextBlock Text="Duração" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="12"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Console / Log -->
        <Border Grid.Row="1" 
                Background="{StaticResource BgDarkBrush}"
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1"
                CornerRadius="8" 
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="Console" 
                               Foreground="{StaticResource AccentGreenBrush}" 
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Button Grid.Column="1" 
                            Content="Limpar"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="11"
                            Padding="8,4"
                            Height="28"
                            Click="ClearLog_Click"/>
                </Grid>

                <ListBox Grid.Row="1" 
                         x:Name="LogListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontFamily="Cascadia Code, Consolas, monospace"
                         FontSize="12"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         ItemsSource="{Binding LogEntries}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" 
                                       TextWrapping="NoWrap"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
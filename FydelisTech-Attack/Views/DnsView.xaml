<UserControl x:Class="FydelisTech_Attack.WPF.Views.DnsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <ScrollViewer>
        <StackPanel Margin="0,0,0,15">

            <!-- Cabeçalho -->
            <TextBlock Text="📡 DNS Enumeration" 
                       Foreground="{StaticResource AccentCyanBrush}"
                       FontSize="20" FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Domínio -->
            <Border Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Domínio:" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontWeight="SemiBold" Width="80"/>
                    <TextBlock Grid.Column="1" x:Name="DomainText"
                               Foreground="{StaticResource AccentGreenBrush}"
                               FontSize="16" FontWeight="Bold"/>
                </Grid>
            </Border>

            <!-- A Records -->
            <Border Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="A Records (IPv4)" 
                               Foreground="{StaticResource AccentYellowBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" x:Name="ARecordList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontFamily="Cascadia Code, Consolas"
                             FontSize="13"
                             MaxHeight="150"/>
                </Grid>
            </Border>

            <!-- MX Records -->
            <Border Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="MX Records (Mail Exchange)" 
                               Foreground="{StaticResource AccentYellowBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" x:Name="MxRecordList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontFamily="Cascadia Code, Consolas"
                             FontSize="13"
                             MaxHeight="150"/>
                </Grid>
            </Border>

            <!-- NS Records -->
            <Border Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="NS Records (Name Servers)" 
                               Foreground="{StaticResource AccentYellowBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" x:Name="NsRecordList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontFamily="Cascadia Code, Consolas"
                             FontSize="13"
                             MaxHeight="150"/>
                </Grid>
            </Border>

            <!-- TXT Records -->
            <Border Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="TXT Records" 
                               Foreground="{StaticResource AccentYellowBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" x:Name="TxtRecordList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontFamily="Cascadia Code, Consolas"
                             FontSize="13"
                             MaxHeight="150"/>
                </Grid>
            </Border>

            <!-- CNAME Records -->
            <Border Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="CNAME Records" 
                               Foreground="{StaticResource AccentYellowBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" x:Name="CnameRecordList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontFamily="Cascadia Code, Consolas"
                             FontSize="13"
                             MaxHeight="150"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
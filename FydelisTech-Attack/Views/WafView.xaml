<UserControl x:Class="FydelisTech_Attack.WPF.Views.WafView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <ScrollViewer>
        <StackPanel Margin="0,0,0,15">

            <!-- Cabeçalho -->
            <TextBlock Text="🛡️ WAF Detection" 
                       Foreground="{StaticResource AccentCyanBrush}"
                       FontSize="20" FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Status do WAF -->
            <Border Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="20" Margin="0,0,0,15">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            x:Name="WafIconBorder"
                            Width="80" Height="80"
                            CornerRadius="40"
                            Background="{StaticResource SuccessBgBrush}"
                            BorderThickness="0"
                            Margin="0,0,20,0">
                        <TextBlock x:Name="WafIconText"
                                   Text="✅"
                                   FontSize="36"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="WafTitle"
                                   Text="Nenhum WAF Detectado"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreenBrush}"/>
                        <TextBlock x:Name="WafVendor"
                                   Text=""
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,5,0,0"/>
                        <TextBlock x:Name="WafConfidence"
                                   Text="Confiança: Baixa"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Assinaturas Detectadas -->
            <Border Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Assinaturas Detectadas" 
                               Foreground="{StaticResource AccentYellowBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <ListBox Grid.Row="1" x:Name="SignatureList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="13"
                             FontFamily="Cascadia Code, Consolas"
                             MinHeight="80"
                             MaxHeight="200"/>
                </Grid>
            </Border>

            <!-- URLS Testadas -->
            <Border Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Payloads Enviados" 
                               Foreground="{StaticResource AccentYellowBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <ListBox Grid.Row="1" x:Name="PayloadList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="13"
                             FontFamily="Cascadia Code, Consolas"
                             MinHeight="80"
                             MaxHeight="200"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
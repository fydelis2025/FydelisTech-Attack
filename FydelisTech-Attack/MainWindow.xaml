<Window x:Class="FydelisTech_Attack.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FydelisTech_Attack"
        mc:Ignorable="d"
        Title="FydelisTech_Attack — OSINT Reconnaissance Suite"
        Width="1400" Height="850"
        MinWidth="1024" MinHeight="700"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Background="{StaticResource BgMediumBrush}">
            <DockPanel LastChildFill="False" Margin="0">

                <!-- Logo / Marca -->
                <Border DockPanel.Dock="Top" 
                        BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="0,0,0,1"
                        Padding="15,20">
                    <StackPanel>
                        <Image Source="/logo.png" 
                               Width="120" Height="120" 
                               HorizontalAlignment="Center"/>
                        <TextBlock Text="FydelisTech-ATTACK" 
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   FontSize="18" FontWeight="Bold"
                                   TextAlignment="Center"
                                   FontFamily="Cascadia Code, Consolas"/>
                        <TextBlock Text="Autor Adiel Fontes" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" 
                                   TextAlignment="Center"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="v1.0.0" 
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="9" 
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Navegação -->
                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                    <RadioButton x:Name="NavDashboard" 
                                 Content="   Dashboard"
                                 GroupName="Navigation"
                                 IsChecked="True"
                                 Style="{StaticResource NavButtonStyle}"
                                 Margin="8,2"/>

                    <RadioButton x:Name="NavDns" 
                                 Content="   DNS Enumeration"
                                 GroupName="Navigation"
                                 Style="{StaticResource NavButtonStyle}"
                                 Margin="8,2"/>

                    <RadioButton x:Name="NavSubdomain" 
                                 Content="   Subdomain Scan"
                                 GroupName="Navigation"
                                 Style="{StaticResource NavButtonStyle}"
                                 Margin="8,2"/>

                    <RadioButton x:Name="NavHttp" 
                                 Content="   HTTP Probe"
                                 GroupName="Navigation"
                                 Style="{StaticResource NavButtonStyle}"
                                 Margin="8,2"/>

                    <RadioButton x:Name="NavWaf" 
                                 Content="   WAF Detection"
                                 GroupName="Navigation"
                                 Style="{StaticResource NavButtonStyle}"
                                 Margin="8,2"/>
                    <RadioButton x:Name="NavExploit" 
                                 Content="  Exploit Suite"
                                 GroupName="Navigation"
                                 Style="{StaticResource NavButtonStyle}"
                                 Margin="8,2"/>

                    <Separator Margin="8,10"/>

                    <RadioButton x:Name="NavReports" 
                                 Content="   Relatórios"
                                 GroupName="Navigation"
                                 Style="{StaticResource NavButtonStyle}"
                                 Margin="8,2"/>
                </StackPanel>

                <!-- Ações rápidas no rodapé -->
                <StackPanel DockPanel.Dock="Bottom" Margin="10,0,10,15">
                    <Separator Margin="0,0,0,10"/>
                    <Button Content="Exportar JSON" 
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,0,5"
                            Click="ExportJson_Click"/>
                    <Button Content="Exportar HTML" 
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,0,5"
                            Click="ExportHtml_Click"/>
                    <Button Content="Abrir Relatório" 
                            Style="{StaticResource SecondaryButton}"
                            Click="OpenReportFolder_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== CONTEÚDO PRINCIPAL ===== -->
        <Grid Grid.Column="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Topo: Input e controles -->
            <Border Grid.Row="0" 
                    Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="15" Margin="0,0,0,10">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="Alvo:" 
                               Foreground="{StaticResource AccentCyanBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <TextBox Grid.Column="1" 
                             x:Name="TargetTextBox"
                             Text="exemplo.com"
                             FontSize="14"/>

                    <Button Grid.Column="2" 
                            x:Name="ScanButton"
                            Content="▶  INICIAR SCAN"
                            Style="{StaticResource PrimaryButton}"
                            Margin="10,0,0,0"
                            Click="StartScan_Click"/>

                    <Button Grid.Column="3" 
                            x:Name="StopButton"
                            Content="⏹  PARAR"
                            Style="{StaticResource SecondaryButton}"
                            Margin="5,0,0,0"
                            IsEnabled="False"
                            Click="StopScan_Click"/>

                    <Button Grid.Column="4" 
                            x:Name="ClearButton"
                            Content="🗑  Limpar"
                            Style="{StaticResource SecondaryButton}"
                            Margin="5,0,0,0"
                            Click="ClearResults_Click"/>

                    <Button Grid.Column="5" 
                            x:Name="SettingsButton"
                            Content="⚙"
                            Width="40"
                            Style="{StaticResource SecondaryButton}"
                            Margin="5,0,0,0"
                            Click="Settings_Click"/>
                </Grid>
            </Border>

            <!-- Área de visualização principal -->
            <ContentControl Grid.Row="1" 
                            x:Name="MainContentArea"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>

            <!-- Status Bar -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,6" Margin="0,10,0,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               x:Name="StatusText"
                               Text="Pronto"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>

                    <!-- Indicador de progresso -->
                    <ProgressBar Grid.Column="1"
                                 x:Name="ScanProgress"
                                 Width="150"
                                 Height="16"
                                 Margin="0,0,15,0"
                                 Foreground="{StaticResource AccentGreenBrush}"
                                 Background="{StaticResource BgDarkBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 Minimum="0" Maximum="100"
                                 Value="0"/>

                    <TextBlock Grid.Column="2" 
                               x:Name="HostCountText"
                               Text="Hosts: 0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,15,0"/>

                    <TextBlock Grid.Column="3"
                               x:Name="ServiceCountText"
                               Text="Serviços: 0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,15,0"/>

                    <TextBlock Grid.Column="4"
                               x:Name="TimerText"
                               Text="00:00"
                               Foreground="{StaticResource AccentGreenBrush}"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

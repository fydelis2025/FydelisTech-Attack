<Application x:Class="FydelisTech_Attack.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FydelisTech_Attack.WPF.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Colors.xaml" />
                <ResourceDictionary Source="/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters Globais -->
            <converters:BoolToStatusConverter x:Key="BoolToStatusConverter" />
            <converters:BoolToStatusColorConverter x:Key="BoolToStatusColorConverter" />
            <converters:HttpStatusToColorConverter x:Key="HttpStatusToColorConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            
        </ResourceDictionary>
    </Application.Resources>
</Application>